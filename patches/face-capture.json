{
  "name": "Face Capture",
  "width": 900,
  "height": 1000,

  "objects": {
    "loadmess_init": { "type": "newobj", "text": "loadmess 100 100 300 640 360", "pos": [250, 30] },
    "unpack_init": { "type": "newobj", "text": "unpack 0 0 0 0 0", "pos": [250, 60] },

