    "play_toggle": { "type": "toggle", "pos": [400, 750], "presentation": [345, 267] },
    "play_rate_label": { "type": "comment", "text": "play rate (ms)", "pos": [475, 735], "presentation": [385, 250] },
    "play_rate": { "type": "number", "pos": [460, 750], "attrs": { "minimum": 10, "maximum": 2000 }, "presentation": [380, 267, 60, 22] },
    "play_metro": { "type": "newobj", "text": "metro 100", "pos": [400, 785] },

    "read_counter": { "type": "newobj", "text": "counter", "pos": [400, 820] },
    "prepend_out": { "type": "newobj", "text": "prepend outputmatrix", "pos": [400, 850] },

    "layer": {
      "type": "newobj",
      "text": "jit.gl.layer ctx",
      "pos": [400, 890],
      "inlets": 1,
      "outlets": 2,
      "outlettype": ["jit_matrix", ""]
    },
    "render": {
      "type": "newobj",
      "text": "jit.gl.render ctx @erase_color 0. 0. 0. 1.",
      "pos": [550, 925],
      "inlets": 1,
      "outlets": 2,
      "outlettype": ["bang", ""]
    },
    "render_trig": { "type": "newobj", "text": "t b b", "pos": [400, 925] },
    "window": {
      "type": "newobj",
      "text": "jit.window ctx @size 640 480 @title \"Face Capture Playback\"",
      "pos": [400, 960],
      "inlets": 1,
      "outlets": 2,
      "outlettype": ["bang", ""]
    },

    "info": { "type": "comment", "text": "Select camera, click capture. Detected faces trigger frame storage. Click play to sequence captured frames.", "pos": [30, 970], "presentation": [10, 355, 430, 22] }
