    ["rest_init", 0, "rest_slider", 0],

    ["slider", 1, "pitch_display", 0],
    ["rest_slider", 1, "note_gate", 0],
    ["pitch_display", 0, "note_gate", 1],
    ["note_gate", 0, "makenote", 0],

    ["velocity", 0, "makenote", 1],
    ["duration", 0, "makenote", 2],

    ["makenote", 0, "pack_note", 0],
    ["makenote", 1, "pack_note", 1],
    ["pack_note", 0, "midiformat", 0],
