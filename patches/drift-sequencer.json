{
  "name": "Drift Sequencer",
  "width": 700,
  "height": 830,
  "objects": {
    "loadmess": { "type": "newobj", "text": "loadmess 200 100 150", "pos": [250, 30] },
    "unpack_init": { "type": "newobj", "text": "unpack 0 0 0", "pos": [250, 60] },

    "tempo": { "type": "number", "pos": [65, 100], "attrs": { "minimum": 50, "maximum": 2000 } },
    "tempo_label": { "type": "comment", "text": "<-- tempo (ms)", "pos": [120, 102] },
    "onoff": { "type": "toggle", "pos": [30, 135] },
    "metro": { "type": "newobj", "text": "metro 200", "pos": [30, 165] },

    "steps": { "type": "newobj", "text": "counter 0 7", "pos": [30, 200] },
    "step_plus1": { "type": "newobj", "text": "+ 1", "pos": [30, 235] },
    "fetch": { "type": "newobj", "text": "prepend fetch", "pos": [30, 270] },

    "slider": {
      "type": "multislider",
      "pos": [30, 305],
      "size": [200, 120],
      "attrs": {
        "size": 8,
        "setminmax": [36.0, 84.0],
        "setstyle": 1,
        "candicane2": [0.14, 0.69, 0.78, 1.0],
        "slidercolor": [0.14, 0.69, 0.78, 1.0],
        "bgcolor": [0.15, 0.15, 0.15, 1.0],
        "orientation": 1
      }
    },
    "pitch_label": { "type": "comment", "text": "pitch (8 steps, MIDI 36-84)", "pos": [30, 430] },

    "pitch_display": { "type": "number", "pos": [250, 450] },
    "pitch_display_label": { "type": "comment", "text": "<-- current note", "pos": [305, 452] },
    "velocity": { "type": "number", "pos": [340, 490], "attrs": { "minimum": 1, "maximum": 127 } },
    "vel_label": { "type": "comment", "text": "<-- velocity", "pos": [395, 492] },
    "duration": { "type": "number", "pos": [430, 490], "attrs": { "minimum": 10, "maximum": 2000 } },
    "dur_label": { "type": "comment", "text": "<-- duration (ms)", "pos": [485, 492] },

    "makenote": { "type": "newobj", "text": "makenote 100 150", "pos": [250, 530] },
    "pack_note": { "type": "newobj", "text": "pack 60 100", "pos": [250, 565] },
    "midiformat": { "type": "newobj", "text": "midiformat", "pos": [250, 600] },
    "drift": {
      "type": "newobj",
      "text": "abl.device.drift~",
      "pos": [250, 635],
      "inlets": 1,
      "outlets": 2,
      "outlettype": ["signal", "signal"]
    },

    "gain": { "type": "gain~", "pos": [250, 670] },
    "dac": { "type": "ezdac~", "pos": [250, 760] },

    "info": { "type": "comment", "text": "Turn on audio, set pitches, click toggle", "pos": [310, 770] }
  },
  "connections": [
    ["loadmess", 0, "unpack_init", 0],
    ["unpack_init", 0, "tempo", 0],
    ["unpack_init", 1, "velocity", 0],
    ["unpack_init", 2, "duration", 0],

    ["onoff", 0, "metro", 0],
    ["tempo", 0, "metro", 1],

    ["metro", 0, "steps", 0],
    ["steps", 0, "step_plus1", 0],
    ["step_plus1", 0, "fetch", 0],
    ["fetch", 0, "slider", 0],

    ["slider", 1, "pitch_display", 0],
    ["pitch_display", 0, "makenote", 0],

    ["velocity", 0, "makenote", 1],
    ["duration", 0, "makenote", 2],

    ["makenote", 0, "pack_note", 0],
    ["makenote", 1, "pack_note", 1],
    ["pack_note", 0, "midiformat", 0],
    ["midiformat", 0, "drift", 0],

    ["drift", 0, "gain", 0],
    ["drift", 1, "gain", 0],
    ["gain", 0, "dac", 0],
    ["gain", 0, "dac", 1]
  ]
}
