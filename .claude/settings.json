{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/sync_maxpat.py",
            "statusMessage": "Syncing .maxpat spec..."
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "python3 hooks/sync_pasted_maxpat.py",
            "statusMessage": "Checking for pasted .maxpat..."
          }
        ]
      }
    ]
  }
}
